# 守店猫 · 任选一家 OpenAI 兼容的中国大模型供应商即可
# Pick any OpenAI-compatible Chinese LLM provider.

# ---- DeepSeek (推荐 / Recommended, 国内最便宜稳定) ----
LLM_PROVIDER=deepseek
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
LLM_API_KEY=sk-xxxxxxxxxxxxxxxx

# ---- Moonshot / Kimi ----
# LLM_PROVIDER=moonshot
# LLM_BASE_URL=https://api.moonshot.cn/v1
# LLM_MODEL=moonshot-v1-8k
# LLM_API_KEY=sk-xxxxxxxxxxxxxxxx

# ---- 通义千问 (DashScope compatible mode) ----
# LLM_PROVIDER=qwen
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_MODEL=qwen-turbo
# LLM_API_KEY=sk-xxxxxxxxxxxxxxxx

# ---- OpenAI / Claude (海外网络) ----
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini
# LLM_API_KEY=sk-xxxxxxxxxxxxxxxx

# 想在不接 API 的情况下体验 demo？设为 1：
# Want to try the demo without any API key? Set this to 1:
MOCK=0
